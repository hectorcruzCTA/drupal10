{# templates/menu--licenciaturas.html.twig (o tu override) #}
{{ attach_library('drudg8b3/menu_toggle') }}

{# NO pongas la clase 'sidebar-menu' aquí; va en el bloque (wrapper) #}
<div class="card-list-container">
  <ul class="card-list">
    {% for item in items %}
      {% if item.below %}
        {# Ítem padre con submenú #}
        <li class="has-children">
          <div class="item-wrapper">
            <button
              type="button"
              class="toggle-btn"
              aria-expanded="false"
              aria-label="Expandir {{ item.title }}"></button>
            <a href="{{ item.url }}" class="menu-parent-link">{{ item.title }}</a>
          </div>

          <ul class="card-list card-list--nested">
            {% for child in item.below %}
              <li>
                <a href="{{ child.url }}">{{ child.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </li>
      {% else %}
        {# Ítem hoja (sin hijos) #}
        <li>
          <a href="{{ item.url }}">{{ item.title }}</a>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</div>
