{% set heading_id = attributes.id ~ '-menu'|clean_id %}

<nav role="navigation" aria-labelledby="{{ heading_id }}" 
     {{ attributes.removeClass('clearfix').addClass('menu-container', 'navbar', 'navbar-expand-lg') }}>

    {% if not configuration.label_display %}
        {# Proporcionar etiqueta para accesibilidad #}
        {% set title_attributes = title_attributes.addClass('sr-only') %}
    {% endif %}
    
    <h2{{ title_attributes.setAttribute('id', heading_id) }}>{{ configuration.label }}</h2>
    
    {# Contenedor del menú #}
    <div class="menu-wrapper container-fluid">
        <ul class="menu navbar-nav d-flex justify-content-center w-100">
            {{ content }}
        </ul>
    </div>
</nav>
