{#
/**
 * @file
 * Plantilla principal para la vista noticias_pagina_principal, display block_1.
 * AÑADIDOS Y CORRECCIONES:
 * - Se eliminó el título "NOTICIAS" que estaba escrito directamente en el código.
 * - Se reactivó el código que imprime el título dinámico del bloque para que se pueda
 *   controlar desde la interfaz de Drupal.
 */
#}
{%
  set classes = [
    dom_id ? 'js-view-dom-id-' ~ dom_id,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
  ]
%}
<div{{ attributes.addClass(classes) }}> {# Este es el div principal de la vista #}
  <div class="container"> {# <<< NUESTRO CONTENEDOR BOOTSTRAP 3 >>> #}
    
    {# --- CORRECCIÓN 1: Reactivado y corregido el código que imprime el título dinámico del bloque --- #}
    {{ title_prefix }}
    {% if title %}
      <h2>{{ title }}</h2>
    {% endif %}
    {{ title_suffix }}

    {# --- CORRECCIÓN 2: Eliminada la sección que imprimía el título hardcodeado --- #}
    {# El 'h2' que estaba aquí fue removido para evitar la duplicación. #}

    {% if header %}
      <div class="view-header section">
        {{ header }}
      </div>
    {% endif %}

    {% if exposed %}
      <div class="view-filters section">
        {{ exposed }}
      </div>
    {% endif %}

    {% if attachment_before %}
      <div class="attachment attachment-before section">
        {{ attachment_before }}
      </div>
    {% endif %}

    {% if rows %}
      <div class="view-content section">
        {{ rows }} {# AQUÍ ES DONDE SE RENDERIZAN TUS FILAS #}
      </div>
    {% elseif empty %}
      <div class="view-empty section">
        {{ empty }}
      </div>
    {% endif %}

    {% if pager %}
      {{ pager }}
    {% endif %}

    {% if attachment_after %}
      <div class="attachment attachment-after section">
        {{ attachment_after }}
      </div>
    {% endif %}

    {% if more %}
      {{ more }}
    {% endif %}

    {% if footer %}
      <div class="view-footer section">
        {{ footer }}
      </div>
    {% endif %}

  </div> {# <<< CIERRE DE NUESTRO CONTENEDOR BOOTSTRAP 3 >>> #}
</div>