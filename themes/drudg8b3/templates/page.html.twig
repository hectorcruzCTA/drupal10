{# themes/drudg8b3/templates/page.html.twig #}

{# Librerías globales #}
{{ attach_library('drudg8b3/global-scripts') }}
{{ attach_library('drudg8b3/bootstrap-carrusel') }}

{# Menú principal UDG (Colapsable) #}
{% if page.udg_menu_principal %}
  <div id="udg_menu_principal_ul" class="container-fluid">
    <button id="menu-toggle" class="btn btn-primary">Menú Principal UDG</button>
    <div id="menu-content" class="menu-collapsed">
      {{ page.udg_menu_principal }}
    </div>
  </div>
{% endif %}

{# Listón UDG (Menú superior) #}
{% if page.liston %}
  <div id="liston" class="container-fluid">
    {{ page.liston }}
  </div>
{% endif %}

{# Barra de administración #}
{% if page.toolbar %}
  <div id="toolbar-administration">
    {{ page.toolbar }}
  </div>
{% endif %}

{# Header con logo, título y buscador #}
<header class="navbar navbar-default" id="navbar">
  <div id="header-navigation-wrapper" class="container">
    <div class="container header">
      <div class="header-content">
        <div id="logo-buscador" class="logo-buscador">
          <div class="logo">
            {{ page.logo_udg }}
          </div>
          <div class="buscador">
            {{ page.buscador }}
          </div>
        </div>
        <div id="titulo-cuaad" class="titulo">
          {{ page.titulo_cuaad }}
        </div>
      </div>
    </div>
  </div>
</header>

{# Menú principal debajo del Listón #}
{% if page.navigation %}
  <nav id="menu-principal" class="container-fluid">
    <div class="container navigation">
      {{ page.navigation }}
    </div>
  </nav>
{% elseif page.navigation_collapsible %}
  <nav id="menu-principal" class="container-fluid">
    <div class="container navigation">
      {{ page.navigation_collapsible }}
    </div>
  </nav>
{% endif %}

{# --- Slideshow siempre visible con fallback basado en contenido del view --- #}
{% set slideshow_html = page.slideshow|render %}
<div id="slideshow" class="section-slideshow-wrapper full-width-region">
  {# Si el view tiene items (clase views-row), muestro el carrusel #}
  {% if slideshow_html matches '/views-row/' %}
    {{ slideshow_html|raw }}
  {% else %}
  {% endif %}
</div>

{# --- Secciones contenidas adicionales --- #}
{% set contained_sections = [
  'precontent2','precontent3',
  'content2','content3','content5','content6','content7','content8','content9','content10','content11'
] %}
{% for section_name in contained_sections %}
  {% if attribute(page, section_name) %}
    <div id="{{ section_name | clean_class }}" class="container section-{{ section_name | clean_class }}-wrapper">
      <div class="container section-content-inner">
        {{ attribute(page, section_name) }}
      </div>
    </div>
  {% endif %}
{% endfor %}

{# Contenedor principal de contenido y sidebar #}
<div class="container">
  <div class="row">
    {% if page.content %}
      <main class="col-md-8" id="main-content">
        {{ page.content }}
      </main>
    {% endif %}
    {% if page.sidebar_second %}
      <aside class="col-md-4" id="sidebar-second">
        {{ page.sidebar_second }}
      </aside>
    {% endif %}
  </div>
</div>

{# Footer #}
<footer id="footer" class="footer-wrapper">
  <div id="footer1-wrapper">
    <div id="footer1-info">
      {{ page.footer1 }}
    </div>
    <div id="footer1-extras">
      {{ page.redes_sociales }}
      {{ page.footer_menu }}
    </div>
  </div>
  <div id="footer2-wrapper">
    {{ page.footer2 }}
  </div>
</footer>
